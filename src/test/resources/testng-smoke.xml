<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Rest API Automation Framework Smoke Suite" verbose="2" parallel="methods" thread-count="3" data-provider-thread-count="3">
    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryListener"/>
    </listeners>
    <!-- Run smoke group -->
    <test name="APITests">
        <groups>
            <run>
                <include name="smoke"></include>
            </run>
        </groups>
        <classes>
            <class name="tests.BookingAPITest"/>
            <class name="tests.CountriesGraphQLAPITest"/>
        </classes>
    </test>
</suite>