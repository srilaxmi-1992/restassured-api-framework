<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Rest API Automation Framework Smoke Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    <!-- Run all Groups (optional) -->
    <test name="APITests">
        <groups>
            <run>
                <include name="smoke"></include>
            </run>
        </groups>
        <classes>
            <class name="tests.BookingAPITest"/>
        </classes>
    </test>
</suite>